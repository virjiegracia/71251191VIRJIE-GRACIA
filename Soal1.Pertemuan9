def cek_anagram(kata1, kata2):
    kata1 = sorted(kata1.lower())
    kata2 = sorted(kata2.lower())
    
    if kata1 == kata2:
        return "Anagram"
    else:
        return "Tidak Anagram"

kata1 = input("Masukkan kata pertama: ")
kata2 = input("Masukkan kata kedua: ")

print("Hasil:", cek_anagram(kata1, kata2))
