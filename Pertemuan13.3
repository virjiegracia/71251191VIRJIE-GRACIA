fname = input("Masukan nama file: ")
fhand = open(fname)
counts = {}

for line in fhand:
    if line.startswith("From "):
        words = line.split()

        time = words[5]
        hour = time.split(":")[0]
        counts[hour] = counts.get(hour, 0) + 1

for key, value in sorted(counts.items()):
    print(key, value)
