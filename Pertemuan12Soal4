fname = input("Masukkan nama file: ") 
fhand = open(fname) 
domain_count = {} 
 
for line in fhand: 
     
    if line.startswith("From "): 
        words = line.split() 
        email = words[1] 
        domain = email.split("@")[1] 
        domain_count[domain] = domain_count.get(domain, 0) + 1 
         
print(domain_count)
