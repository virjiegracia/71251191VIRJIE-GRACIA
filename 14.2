def konversi():  
    list1 = ['Virji', 'Cheila', 'Alicia', 'Valin']  
    print('\n1. List awal: ', list1)  
    listSet = set(list1)  
    print('List ke Set: ', listSet)  
   
    SetList = list(listSet)       
    print('Set ke List: ', SetList)  
    
    tuple1 = ('Virji', 'Cheila', 'Alicia', 'Valin')  
    print('\n2. Tuple Awal: ', tuple1)  
    tupleSet = set(tuple1)  
    print('Tuple ke Set: ', tupleSet)  
     
    setTuple = tuple(tupleSet)    
    print('Set ke Tuple: ', setTuple)  
 
konversi() 
